#!/usr/bin/env bash


human() {
    awk -v b="${1}" 'BEGIN {
        if (b >= 1099511627776) printf "%.2f TiB\n", b / 1099511627776
        else if (b >= 1073741824) printf "%.2f GiB\n", b / 1073741824
        else if (b >= 1048576) printf "%.2f MiB\n", b / 1048576
        else if (b >= 1024) printf "%.2f KiB\n", b / 1024
        else printf "%d B\n", b
    }'
}


to_bytes() {
    echo "${1}" | awk '
    {
        val = toupper($0)
        num = val; gsub(/[A-Z ]+/, "", num)
        unit = val; gsub(/[0-9. ]+/, "", unit)

        # Base-2 (IEC 표준 - 1024 단위)
        if (unit == "TIB") num *= 1099511627776
        else if (unit == "GIB") num *= 1073741824
        else if (unit == "MIB") num *= 1048576
        else if (unit == "KIB") num *= 1024
        # Base-10 (클라우드/SI 표준 - 1000 단위)
        else if (unit == "TB" || unit == "T") num *= 1000000000000
        else if (unit == "GB" || unit == "G") num *= 1000000000
        else if (unit == "MB" || unit == "M") num *= 1000000
        else if (unit == "KB" || unit == "K") num *= 1000

        printf "%.0f\n", num
    }'
}


get_stat_embed() {
    local date_val=$(echo "${1}" | tr -d '\n\r"')
    local rx_val=$(echo "${2}" | tr -d '\n\r"')
    local tx_val=$(echo "${3}" | tr -d '\n\r"')
    local timestamp=$(echo "${4}" | tr -d '\n\r"')
    local tx_percent=$(echo "${5}" | tr -d '\n\r"')

    local desc="# tx: ${tx_val}"
    [[ -n "${tx_percent}" ]] && desc="${desc} (${tx_percent})"

    cat <<EOF
{
  "content": "",
  "username": "${NAME}@$(hostname)",
  "embeds": [
    {
      "title": "트래픽 사용량",
      "description": "${desc}",
      "color": 4320097,
      "fields": [
        {
          "name": "수신",
          "value": "${rx_val}",
          "inline": true
        },
        {
          "name": "발신",
          "value": "${tx_val}",
          "inline": true
        },
        {
          "name": "기간",
          "value": "${date_val}",
          "inline": true
        }
      ],
      "timestamp": "${timestamp}",
      "footer": {
        "text": "vnStat"
      }
    }
  ]
}
EOF
}


get_warning_embed() {
    local msg=$(echo "${1}" | tr -d '\n\r"')
    local timestamp=$(date +"%Y-%m-%dT%H:%M:%S%:z")
    cat <<EOF
{
  "content": "@everyone",
  "username": "${NAME}@$(hostname)",
  "embeds": [
    {
      "title": "트래픽 경고",
      "description": "${msg}",
      "color": 13993533,
      "timestamp": "${timestamp}",
      "footer": {
        "text": "vnStat"
      }
    }
  ]
}
EOF
}


block_output() {
    if ! iptables -C OUTPUT -j DROP 2>/dev/null; then
        msg="아웃바운드 차단을 설정했습니다."
        log I "${msg}"
        discord_send -j "$(get_warning_embed "${msg}")"

        local ports
        ports=$(IFS=,; echo "${TRAFFIC_ALLOWED_PORTS[*]}")
        if [[ -n "${ports}" ]]; then
            iptables -I OUTPUT 1 -p tcp -m multiport --sports "${ports}" -j ACCEPT
            iptables -I OUTPUT 1 -p tcp -m multiport --dports "${ports}" -j ACCEPT
            iptables -I OUTPUT 1 -p udp -m multiport --sports "${ports}" -j ACCEPT
            iptables -I OUTPUT 1 -p udp -m multiport --dports "${ports}" -j ACCEPT
        fi
        iptables -I OUTPUT 1 -o lo -j ACCEPT
        iptables -A OUTPUT -j DROP
    fi
}


unblock_output() {
    if iptables -C OUTPUT -j DROP 2>/dev/null; then
        while iptables -D OUTPUT -j DROP 2>/dev/null; do :; done

        local ports
        ports=$(IFS=,; echo "${TRAFFIC_ALLOWED_PORTS[*]}")
        while iptables -D OUTPUT -o lo -j ACCEPT 2>/dev/null; do :; done
        if [[ -n "${ports}" ]]; then
            while iptables -D OUTPUT -p tcp -m multiport --dports "${ports}" -j ACCEPT 2>/dev/null; do :; done
            while iptables -D OUTPUT -p tcp -m multiport --sports "${ports}" -j ACCEPT 2>/dev/null; do :; done
            while iptables -D OUTPUT -p udp -m multiport --dports "${ports}" -j ACCEPT 2>/dev/null; do :; done
            while iptables -D OUTPUT -p udp -m multiport --sports "${ports}" -j ACCEPT 2>/dev/null; do :; done
        fi
        msg="아웃바운드 차단이 해제되었습니다."
        log I "${msg}"
        discord_send -j "$(get_warning_embed "${msg}")"
    fi
}


check(){
    local threshold_bytes=$(to_bytes "${TRAFFIC_THRESHOLD}")

    local is_unlimited=false
    if [[ "${TRAFFIC_THRESHOLD,,}" == "0" || "${TRAFFIC_THRESHOLD,,}" == "infinity" || "${TRAFFIC_THRESHOLD,,}" == "unlimited" ]]; then
        is_unlimited=true
    elif [[ -z "${threshold_bytes}" || "${threshold_bytes}" == "0" ]]; then
        log E "TRAFFIC_THRESHOLD 형식이 올바르지 않습니다: ${TRAFFIC_THRESHOLD} (예: 500GB, 1.5TB, 0, unlimited)."
        return 1
    fi

    local curr_y=$(date -u +%Y)
    local curr_m=$(date -u +%-m)

    local parsed=$(TZ=UTC vnstat -m --json -i "${TRAFFIC_INTERFACE}" | jq -r '.interfaces[0].traffic.month[-1] | "\(.tx) \(.rx) \(.date.year) \(.date.month)"')
    read -r tx rx y m <<< "${parsed}"
    local timestamp=$(date -u +"%Y-%m-%dT%H:%M:%S.000Z")

    if [[ "${y}" != "${curr_y}" || "${m}" != "${curr_m}" ]]; then
        msg="최근 기록(${y}-${m})이 이번 달(${curr_y}-${curr_m})과 일치하지 않습니다."
        log E "${msg}"
        discord_send -j "$(get_warning_embed "${msg}")"
        return 1
    fi

    if [[ ! "${tx}" =~ ^[0-9]+$ ]] || [[ ! "${rx}" =~ ^[0-9]+$ ]]; then
        msg="tx 또는 rx 값이 올바른 숫자가 아닙니다. (tx: ${tx}, rx: ${rx})"
        log E "${msg}"
        discord_send -j "$(get_warning_embed "${msg}")"
        return 1
    fi

    rx_human=$(human ${rx})
    tx_human=$(human ${tx})

    stat=$(printf "%04d-%02d | rx: %s | tx: %s\n" "${y}" "${m}" "${rx_human}" "${tx_human}")
    log I "${stat}"
    local tx_percent=""
    if [[ "${is_unlimited}" == false ]]; then
        tx_percent="$(echo "${tx} ${threshold_bytes}" | awk '{printf "%.1f", $1 / $2 * 100}')%"
    fi
    discord_send -j "$(get_stat_embed "$(printf "%04d년 %02d월" "${y}" "${m}")" "${rx_human}" "${tx_human}" "${timestamp}" "${tx_percent}")"

    if [[ "${is_unlimited}" == true ]]; then
        unblock_output
        return 0
    fi

    local state_file="${TRAFFIC_STATE_FILE}_${curr_y}_${curr_m}"
    local last_alerted_percent=0
    [[ -f "${state_file}" ]] && last_alerted_percent=$(cat "${state_file}")

    for percent in "${TRAFFIC_ALERT_PERCENTS[@]}"; do
        local limit_bytes=$(echo "${threshold_bytes} ${percent}" | awk '{printf "%.0f", $1 * $2 / 100}')
        if (( tx >= limit_bytes )); then

            if (( percent <= last_alerted_percent )); then
                break
            fi

            local limit_human=$(human ${limit_bytes})
            msg="현재 발신량(${tx_human})이 허용량의 ${percent}%(${limit_human})를 초과했습니다."
            log E "${msg}"
            discord_send -j "$(get_warning_embed "${msg}")"

            echo "${percent}" > "${state_file}"
            break
        fi
    done

    local block_limit_bytes=$(echo "${threshold_bytes} ${TRAFFIC_BLOCK_PERCENT}" | awk '{printf "%.0f", $1 * $2 / 100}')
    if (( tx >= block_limit_bytes )); then
        block_limit_bytes_human=$(human "${block_limit_bytes}")
        log E "현재 발신량(${tx_human})이 ${TRAFFIC_BLOCK_PERCENT}% 차단 임계치(${block_limit_bytes_human})를 초과했습니다."
        block_output
    else
        unblock_output
    fi
}


traffic_manager(){
    case "${1}" in
        "block")
            log I "SSH를 제외한 OUTPUT을 차단합니다."
            block_output
            ;;
        "unblock")
            log I "OUTPUT 차단을 해제합니다."
            unblock_output
            ;;
        "check")
            log I "이번 달 트래픽을 확인합니다."
            check
            ;;
        *)
            log E "사용법 :
traffic check
        block
        unblock"
            ;;
    esac
}